<?xml version="1.0" encoding="utf-8"?>
<!--Form view,List view of Recurring Template and also menu item under configuration that opens the views-->
<odoo>
    <record id="recurring_template_form" model="ir.ui.view">
        <field name="name">recurring.template.form</field>
        <field name="model">recurring.template</field>
        <field name="arch" type="xml">
            <form string="Recurring Template" >
                <header>
                     <field name="state"  options="{'clickable':'1'}"  widget="statusbar" statusbar_visible="draft,running"/>
                </header>
                <sheet>
                    <group>
                        <group name="general_information1">
                            <field name="name"/>
                            <field name="pay_time"/>
                            <field name="credit_account_id" />
                            <field name="debit_account_id" />
                            <field name="journal_id" />
                        </group>
                        <group name="general_information2">
                            <field name="recurring_period"/>
                            <field name="recurring_interval"/>
                            <field name="start_date" />
                            <field name="next_date" />
                            <field name="end_date" />
                            <field name="amount" />
                            <field name="generate_journal_as" />
                        </group>
                    </group>
                    <field name="description" placeholder="Description..."/>
                </sheet>
            </form>
        </field>
    </record>

     <record id="recurring_template_list" model="ir.ui.view">
        <field name="name">recurring.template.list</field>
        <field name="model">recurring.template</field>
        <field name="arch" type="xml">
            <list string="recurring template" >
                 <field name="start_date"/>
                 <field name="name"/>
                 <field name="amount" />
            </list>
        </field>
    </record>

       <record id="action_recurring_template" model="ir.actions.act_window">
        <field name="name">Recurring Template</field>
        <field name="res_model">recurring.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem action="action_recurring_template"
        id="recurring_template_menu"
        parent="account.root_payment_menu"
        sequence="10"/>

</odoo>


